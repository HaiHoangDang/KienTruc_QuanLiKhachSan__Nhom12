@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Khu vực nhân viên";
}

<div class="p-10 bg-white rounded-3xl shadow-lg">
    <h1 class="text-3xl font-semibold mb-4">Khu vực nhân viên lễ tân</h1>
    <p class="text-slate-600 mb-6">Xem danh sách khách hàng, phản hồi nhanh và cập nhật trạng thái phòng trong hệ thống.</p>
    <ul class="space-y-3">
        <li class="rounded-2xl border border-slate-200 p-4 bg-slate-50">
            <strong class="block text-lg">Quản lý check-in</strong>
            <span class="text-sm text-slate-500">Xác nhận khách, cấp thẻ phòng và ghi chú đặc biệt.</span>
        </li>
        <li class="rounded-2xl border border-slate-200 p-4 bg-slate-50">
            <strong class="block text-lg">Phản hồi nhanh</strong>
            <span class="text-sm text-slate-500">Xử lý yêu cầu bổ sung và chat nội bộ với bộ phận dịch vụ.</span>
        </li>
    </ul>
</div>
