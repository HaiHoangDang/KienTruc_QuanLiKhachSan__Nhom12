@* Floating chat assistant *@

<link rel="stylesheet" href="~/Content/dksh-chat.css" />
<div id="dkshChatWidget" class="dksh-chat-widget" aria-live="polite">
    <button id="dkshChatToggle" class="dksh-chat-toggle" type="button" aria-label="Mở chat hỗ trợ">
        <i class="fas fa-comment-alt"></i>
    </button>

    <div id="dkshChatPanel" class="dksh-chat-panel" role="dialog" aria-hidden="true">
        <header class="dksh-chat-header">
            <div>
                <strong>Trợ lý khách hàng</strong>
                <span>Chuỗi khách sạn DHS</span>
            </div>
            <button type="button" id="dkshChatClose" class="dksh-chat-close" aria-label="Đóng chat">
                <i class="fas fa-times"></i>
            </button>
        </header>

        <div class="dksh-chat-body" id="dkshChatBody">
            <div class="dksh-chat-message dksh-chat-message-bot">
                Chào bạn! Mình có thể giúp bạn với thông tin khách sạn, phòng trống và dịch vụ trong chuỗi DKS.
            </div>
        </div>

        <form id="dkshChatForm" class="dksh-chat-form">
            <input id="dkshChatInput" type="text" maxlength="500" placeholder="Hỏi về khách sạn, phòng trống, dịch vụ..." autocomplete="off">
            <button type="submit" aria-label="Gửi tin nhắn">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

<script>
    (function () {

        const widget = document.getElementById('dkshChatWidget');
        const toggle = document.getElementById('dkshChatToggle');
        const panel = document.getElementById('dkshChatPanel');
        const closeBtn = document.getElementById('dkshChatClose');
        const form = document.getElementById('dkshChatForm');
        const input = document.getElementById('dkshChatInput');
        const body = document.getElementById('dkshChatBody');

        // =========================
        // render message
        // =========================
        const appendMessage = (type, text) => {

            const message = document.createElement('div');

            message.className =
                `dksh-chat-message dksh-chat-message-${type}`;

            message.textContent = text;

            body.appendChild(message);

            body.scrollTop = body.scrollHeight;
        };

        // =========================
        // LOAD HISTORY
        // =========================
        const loadHistory = async () => {
            console.log("LOADING HISTORY");

            try {

                const response = await fetch('/ChatBot/History');

                const messages = await response.json();

                body.innerHTML = '';

                if (messages.length === 0) {

                    appendMessage(
                        'bot',
                        'Chào bạn! Mình có thể giúp bạn với thông tin khách sạn, phòng trống và dịch vụ trong chuỗi DKS.'
                    );

                    return;
                }

                messages.forEach(msg => {

                    const type =
                        msg.role === "assistant"
                            ? "bot"
                            : "user";

                    appendMessage(type, msg.content);

                });

            }
            catch (error) {

                console.error('Load history error:', error);

            }
        };

        // =========================
        // OPEN / CLOSE PANEL
        // =========================
        const togglePanel = async () => {

            const isHidden =
                !panel.classList.contains('active');

            panel.classList.toggle('active', isHidden);

            panel.setAttribute('aria-hidden', !isHidden);

            if (isHidden) {

                await loadHistory();

                input.focus();
            }
        };

        toggle.addEventListener('click', function () {

            togglePanel();

        });

        closeBtn.addEventListener('click', function () {

            panel.classList.remove('active');

            panel.setAttribute('aria-hidden', 'true');

        });

        // =========================
        // SEND MESSAGE
        // =========================
        form.addEventListener('submit', async function (event) {

            event.preventDefault();

            const text = input.value.trim();

            if (!text) {
                return;
            }

            appendMessage('user', text);

            input.value = '';

            input.disabled = true;

            try {

                const response = await fetch('/ChatBot/Ask', {

                    method: 'POST',

                    headers: {
                        'Content-Type':
                            'application/x-www-form-urlencoded'
                    },

                    body:
                        `message=${encodeURIComponent(text)}`
                });

                const result =
                    await response.json().catch(() => null);

                if (!response.ok) {

                    const serverReply =
                        result && result.reply
                            ? result.reply
                            : 'Không thể kết nối máy chủ.';

                    appendMessage('bot', serverReply);

                    return;
                }

                const reply =
                    result && result.reply
                        ? result.reply
                        : 'Không nhận được phản hồi từ AI.';

                appendMessage('bot', reply);

            }
            catch (error) {

                appendMessage(
                    'bot',
                    'Xin lỗi, hiện tại hệ thống đang lỗi.'
                );

                console.error(error);

            }
            finally {

                input.disabled = false;

                input.focus();

            }
        });

    })();
</script>





