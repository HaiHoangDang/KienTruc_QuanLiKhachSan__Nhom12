@model IEnumerable<DKS_HotelManager.DTOs.Booking.BookingResponse>
@{
    ViewBag.Title = "Danh Sách Đặt Phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .booking-page {
        padding: 0;
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
        min-height: calc(100vh - 75px);
    }

    .page-header {
        background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 50%, #16213e 100%);
        color: #d4af37;
        padding: 50px 0;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

    .page-header-content {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-header h1 {
        font-size: 42px;
        font-weight: 900;
        margin: 0;
        text-shadow: 0 0 30px rgba(212, 175, 55, 0.5);
        letter-spacing: -0.5px;
    }

    .page-header small {
        display: block;
        font-size: 18px;
        font-weight: 500;
        color: rgba(212, 175, 55, 0.8);
        margin-top: 8px;
    }

    .btn-luxury {
        background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
        border: none;
        color: #0a0a1a;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
        padding: 14px 28px;
        border-radius: 12px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
    }

        .btn-luxury:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(212, 175, 55, 0.5);
            background: linear-gradient(135deg, #ffd700 0%, #d4af37 100%);
            color: #0a0a1a;
            text-decoration: none;
        }

        .btn-luxury:active {
            transform: translateY(-1px);
        }

    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px 60px;
    }

    .table-luxury {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        border: 2px solid #e2e8f0;
    }

        .table-luxury table {
            width: 100%;
            border-collapse: collapse;
        }

        .table-luxury thead {
            background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 50%, #16213e 100%);
        }

        .table-luxury th {
            padding: 20px 24px;
            text-align: left;
            color: #d4af37;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            border-bottom: 2px solid rgba(212, 175, 55, 0.3);
        }

        .table-luxury td {
            padding: 20px 24px;
            border-bottom: 1px solid #e2e8f0;
            color: #475569;
            font-size: 14px;
            font-weight: 500;
        }

        .table-luxury tbody tr {
            transition: all 0.3s ease;
        }

            .table-luxury tbody tr:hover {
                background: linear-gradient(90deg, rgba(212, 175, 55, 0.05), rgba(212, 175, 55, 0.02));
                transform: translateX(5px);
            }

            .table-luxury tbody tr:last-child td {
                border-bottom: none;
            }

    .btn {
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: none;
        cursor: pointer;
    }

    .btn-info {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-info:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
            color: #ffffff;
            text-decoration: none;
        }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
            color: #ffffff;
            text-decoration: none;
        }

    .btn-sm {
        padding: 8px 14px;
        font-size: 12px;
    }

    .status-badge {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
    }

    .status-active {
        background: linear-gradient(135deg, #d1fae5, #a7f3d0);
        color: #065f46;
        border: 1px solid #34d399;
    }

    .status-cancel {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #ef4444;
    }

    .status-completed {
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
        color: #3730a3;
        border: 1px solid #6366f1;
    }

    .status-default {
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        color: #334155;
        border: 1px solid #94a3b8;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    @@media (max-width: 768px) {
        .page-header-content {
            padding: 0 20px;
        }

        .page-header h1 {
            font-size: 32px;
        }

        .container {
            padding: 0 20px 40px;
        }

        .table-luxury {
            overflow-x: auto;
        }

            .table-luxury table {
                min-width: 1000px;
            }
    }
</style>

<div class="booking-page">
    <div class="page-header">
        <div class="page-header-content">
            <div>
                <h1>Danh Sách Đặt Phòng</h1>
                <small>Luxury Hotel Chain</small>
            </div>
            <div>
                @Html.ActionLink("Đặt Phòng Mới", "Create", null, new { @class = "btn-luxury" })
            </div>
        </div>
    </div>

    <div class="container">
        <div class="table-luxury">
            <table>
                <thead>
                    <tr>
                        <th>Mã Thuê</th>
                        <th>Mã Đặt Phòng</th>
                        <th>Mã Phòng</th>
                        <th>Mã Nhân Viên</th>
                        <th>Ngày Đặt</th>
                        <th>Ngày Vào</th>
                        <th>Ngày Trả</th>
                        <th>Đặt Cọc</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.MaThue</strong></td>
                            <td>@item.MaDatPhong</td>
                            <td>@item.MaPhong</td>
                            <td>@item.MaNV</td>
                            <td>@(item.NgayDat.HasValue ? item.NgayDat.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@(item.NgayVao.HasValue ? item.NgayVao.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@(item.NgayTra.HasValue ? item.NgayTra.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@(item.DatCoc.HasValue ? item.DatCoc.Value.ToString("N0") + " VNĐ" : "")</td>
                            <td>
                                @{
                                    var statusClass = "status-default";
                                    var statusText = string.IsNullOrEmpty(item.TrangThai) ? "Chưa cập nhật" : item.TrangThai;

                                    if (statusText == "Dang o")
                                    {
                                        statusClass = "status-active";
                                    }
                                    else if (statusText == "Huy")
                                    {
                                        statusClass = "status-cancel";
                                    }
                                    else if (statusText == "Da tra")
                                    {
                                        statusClass = "status-completed";
                                    }
                                }
                                <span class="status-badge @statusClass">@statusText</span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    @Html.ActionLink("Chi Tiết", "Details", new { id = item.MaThue }, new { @class = "btn btn-info btn-sm" })
                                    @Html.ActionLink("Xóa", "Delete", new { id = item.MaThue }, new { @class = "btn btn-danger btn-sm", onclick = "return confirm('Bạn có chắc chắn muốn hủy đặt phòng này?');" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>