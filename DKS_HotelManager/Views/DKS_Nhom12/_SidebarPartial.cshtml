@using DKS_HotelManager.Helpers
@using System
<!-- Sidebar Overlay for Mobile -->
@{
    var currentController = ViewContext.RouteData.Values["controller"] != null
        ? ViewContext.RouteData.Values["controller"].ToString()
        : string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"] != null
        ? ViewContext.RouteData.Values["action"].ToString()
        : string.Empty;
    Func<string, string, bool> Matches = (controller, action) =>
    {
        var matchesController = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var matchesAction = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return matchesController && matchesAction;
    };
    var isHomeIndex = Matches("Home", "Index");
    var isHotelIndex = Matches("Hotel", "Index");
    var isHomeAbout = Matches("Home", "About");
    var isHomeService = Matches("Home", "Service");
    var isAccountIndex = Matches("Account", "Index");
    var isHomeComment = Matches("Home", "Comment");
    var isHomeContact = Matches("Home", "Contact");
}
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <i class="fas fa-hotel"></i>
        </div>
        <h3>Menu</h3>
        <p>Hotel Luxury System</p>
    </div>
    <nav class="sidebar-menu">
        <div class="menu-section">
            <div class="menu-section-title">
                <span>@LanguageHelper.Translate("Home")</span>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Index", "Home")" class='@(isHomeIndex ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-home"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("Home")</span>
                </a>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Index", "Hotel")" class='@(isHotelIndex ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("ExploreHotels")</span>
                </a>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("About", "Home")" class='@(isHomeAbout ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("About")</span>
                </a>
            </div>
        </div>

        <div class="menu-section">
            <div class="menu-section-title">
                <span>@LanguageHelper.Translate("Services")</span>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Service", "Home")" class='@(isHomeService ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-concierge-bell"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("Services")</span>
                </a>
            </div>
        </div>

        <div class="menu-section">
            <div class="menu-section-title">
                <span>@LanguageHelper.Translate("Account")</span>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Index", "Account")" class='@(isAccountIndex ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-user-circle"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("Account")</span>
                </a>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Comment", "Home")" class='@(isHomeComment ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("Comments")</span>
                </a>
            </div>
            <div class="menu-item">
                <a href="@Url.Action("Contact", "Home")" class='@(isHomeContact ? "active" : "")'>
                    <div class="menu-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <span class="menu-text">@LanguageHelper.Translate("Contact")</span>
                </a>
            </div>
            @if (Session["KhachHang"] != null)
            {
                <div class="menu-item logout-item">
                    <a href="@Url.Action("Logout", "Authentication")">
                        <div class="menu-icon">
                            <i class="fas fa-sign-out-alt"></i>
                        </div>
                        <span class="menu-text">@LanguageHelper.Translate("Logout")</span>
                    </a>
                </div>
            }
        </div>
    </nav>
</aside>
