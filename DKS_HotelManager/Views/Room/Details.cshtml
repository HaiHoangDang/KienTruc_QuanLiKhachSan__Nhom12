@model DKS_HotelManager.Models.PHONG

@{
    ViewBag.Title = "Chi Tiết Phòng";
}

@functions {
    private string ResolveRoomImage(string imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return Url.Content("~/Images/no_image.jpg");
        }

        if (imagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase) || imagePath.StartsWith("https", StringComparison.OrdinalIgnoreCase))
        {
            return imagePath;
        }

        if (imagePath.StartsWith("~") || imagePath.StartsWith("/"))
        {
            return Url.Content(imagePath);
        }

        return Url.Content("~/RoomImages/" + imagePath.TrimStart('/'));
    }
    
    private List<string> GetRoomImages(DKS_HotelManager.Models.PHONG room)
    {
        var images = new List<string>();
        if (room.HINHANHs != null && room.HINHANHs.Any())
        {
            images = room.HINHANHs
                .Where(h => !string.IsNullOrEmpty(h.DuongDan))
                .OrderBy(h => h.MaHinh)
                .Select(h => ResolveRoomImage(h.DuongDan))
                .ToList();
        }
        if (!images.Any())
        {
            images.Add(ResolveRoomImage(null));
        }
        return images;
    }
}

<div class="container">
    <div class="page-header" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #d4af37; padding: 30px; border-radius: 10px; margin-bottom: 30px;">
        <h1>Chi Tiết Phòng <small>Luxury Hotel Chain</small></h1>
    </div>

    <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
        @{
            var roomImages = GetRoomImages(Model);
        }
        
        @if (roomImages.Any())
        {
            <div style="margin-bottom: 30px;">
                <h3 style="color: #d4af37; margin-bottom: 15px;">Hình ảnh phòng</h3>
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    @foreach (var imageUrl in roomImages)
                    {
                        <div style="flex: 0 0 auto; width: 250px; height: 180px; overflow: hidden; border-radius: 10px; border: 2px solid #e2e8f0; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                            <img src="@imageUrl" alt="@Model.TenPhong" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                        </div>
                    }
                </div>
            </div>
        }
        
        <dl class="dl-horizontal">
          
            <dt>Mã Phòng:</dt>
            <dd>@Model.MaPhong</dd>

            <dt>Tên Phòng:</dt>
            <dd>@Model.TenPhong</dd>

            <dt>Khách Sạn:</dt>
            <dd>@(Model.KHACHSAN != null ? Model.KHACHSAN.TenKS : "Chưa cập nhật")</dd>

            <dt>Loại Phòng:</dt>
            <dd>@(Model.LOAIPHONG != null ? Model.LOAIPHONG.TenLoai : "Chưa cập nhật")</dd>

            <dt>Sức Chứa:</dt>
            <dd>@Model.SucChua người</dd>

            <dt>Tầng:</dt>
            <dd>Tầng @Model.Tang</dd>

            <dt>Diện Tích:</dt>
            <dd>@(Model.DienTich.HasValue ? Model.DienTich.Value.ToString("F2") + " m²" : "Chưa cập nhật")</dd>

            <dt>Đơn Giá/Ngày:</dt>
            <dd>@Model.DGNgay.ToString("N0") VNĐ</dd>
        </dl>

        <div style="margin-top: 30px;">
            @Html.ActionLink("Sửa", "Edit", new { id = Model.MaPhong }, new { @class = "btn btn-warning" })
            @Html.ActionLink("Xóa", "Delete", new { id = Model.MaPhong }, new { @class = "btn btn-danger" })
            @Html.ActionLink("Quay Lại", "Index", null, new { @class = "btn btn-default" })
        </div>
    </div>
</div>

