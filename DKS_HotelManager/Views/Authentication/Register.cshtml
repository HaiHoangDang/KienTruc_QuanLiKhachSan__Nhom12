@model DKS_HotelManager.Controllers.RegisterViewModel
@using DKS_HotelManager.Helpers
@{
    ViewBag.Title = LanguageHelper.Translate("Register");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .auth-page {
        min-height: calc(100vh - 75px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 25%, #2a2a3e 50%, #1a1a2e 75%, #0a0a1a 100%);
        position: relative;
        overflow: hidden;
    }

    .auth-page::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 1000px;
        height: 1000px;
        background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        animation: float 20s ease-in-out infinite;
    }

    .auth-page::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -30%;
        width: 800px;
        height: 800px;
        background: radial-gradient(circle, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        animation: float 25s ease-in-out infinite reverse;
    }

    @@keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(30px, -30px) scale(1.1); }
    }

    .auth-container {
        max-width: 580px;
        width: 100%;
        position: relative;
        z-index: 10;
    }

    .auth-card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.98) 100%);
        border-radius: 32px;
        padding: 50px 45px;
        box-shadow: 
            0 30px 80px rgba(0, 0, 0, 0.4),
            0 0 0 1px rgba(212, 175, 55, 0.2),
            inset 0 1px 0 rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        animation: slideUp 0.6s ease-out;
        border: 2px solid rgba(212, 175, 55, 0.3);
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .auth-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .auth-logo {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #d4af37, #b8941f);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4); }
        50% { transform: scale(1.05); box-shadow: 0 15px 40px rgba(212, 175, 55, 0.6); }
    }

    .auth-logo i {
        font-size: 36px;
        color: #0a0a1a;
    }

    .auth-header h2 {
        color: #1a1a2e;
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .auth-header p {
        color: #64748b;
        font-size: 15px;
        font-weight: 500;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        display: block;
        margin-bottom: 10px;
        color: #1a1a2e;
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .form-group input {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-size: 15px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-sizing: border-box;
        background: #ffffff;
        color: #1a1a2e;
        font-weight: 500;
    }

    .form-group input:focus {
        outline: none;
        border-color: #d4af37;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15), 0 4px 20px rgba(212, 175, 55, 0.1);
        transform: translateY(-2px);
    }

    .form-group input::placeholder {
        color: #94a3b8;
        font-weight: 400;
    }

    .captcha-group {
        display: flex;
        gap: 12px;
        align-items: stretch;
    }

    .captcha-image,
    .refresh-captcha {
        min-height: 60px;
        padding: 0 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: linear-gradient(135deg, #f8f9fa, #ffffff);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Courier New', monospace;
        font-size: 24px;
        font-weight: 900;
        letter-spacing: 8px;
        color: #1a1a2e;
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .captcha-input {
        flex: 1;
    }

    .captcha-input input {
        width: 100%;
        height: 60px;
        border-radius: 16px;
        border: 2px solid #e2e8f0;
        padding: 0 18px;
        font-size: 16px;
        box-shadow: inset 0 1px 4px rgba(0,0,0,0.05);
    }

    .refresh-captcha {
        min-width: 56px;
        background: linear-gradient(135deg, #f8f9fa, #e2e8f0);
        cursor: pointer;
    }

    .refresh-captcha:hover {
        background: linear-gradient(135deg, #d4af37, #b8941f);
        color: #0a0a1a;
        border-color: #d4af37;
        transform: rotate(180deg);
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }

    .btn-register {
        width: 100%;
        background: linear-gradient(135deg, #d4af37 0%, #b8941f 50%, #d4af37 100%);
        border: none;
        color: #0a0a1a;
        padding: 18px;
        border-radius: 16px;
        font-size: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
        position: relative;
        overflow: hidden;
    }

    .btn-register::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.4), transparent);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn-register:hover::before {
        width: 400px;
        height: 400px;
    }

    .btn-register:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 35px rgba(212, 175, 55, 0.5);
        background: linear-gradient(135deg, #ffd700 0%, #d4af37 50%, #ffd700 100%);
    }

    .btn-register:active {
        transform: translateY(-2px);
    }

    .btn-register i {
        margin-right: 10px;
    }

    .auth-footer {
        text-align: center;
        margin-top: 32px;
        padding-top: 32px;
        border-top: 2px solid #e2e8f0;
    }

    .auth-footer p {
        color: #64748b;
        font-size: 14px;
        margin-bottom: 0;
    }

    .auth-footer a {
        color: #d4af37;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.3s ease;
        border-bottom: 2px solid transparent;
    }

    .auth-footer a:hover {
        color: #b8941f;
        border-bottom-color: #b8941f;
    }

    .alert {
        padding: 16px 20px;
        border-radius: 16px;
        margin-bottom: 24px;
        font-size: 14px;
        font-weight: 500;
        animation: slideDown 0.4s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .alert-danger {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 2px solid #f87171;
        box-shadow: 0 4px 15px rgba(248, 113, 113, 0.2);
    }

    .alert-success {
        background: linear-gradient(135deg, #d1fae5, #a7f3d0);
        color: #065f46;
        border: 2px solid #34d399;
        box-shadow: 0 4px 15px rgba(52, 211, 153, 0.2);
    }

    .field-validation-error {
        color: #dc3545;
        font-size: 13px;
        margin-top: 8px;
        display: block;
        font-weight: 500;
    }

    .input-validation-error {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 4px rgba(220, 53, 69, 0.15) !important;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .auth-card {
            padding: 40px 30px;
            border-radius: 24px;
        }

        .auth-header h2 {
            font-size: 28px;
        }

        .auth-logo {
            width: 70px;
            height: 70px;
        }

        .captcha-group {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h2>@LanguageHelper.Translate("Register")</h2>
                <p>@LanguageHelper.Translate("CreateAccount")</p>
            </div>

            @if (TempData["RegisterError"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> @TempData["RegisterError"]
                </div>
            }

            @if (TempData["RegisterSuccess"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["RegisterSuccess"]
                </div>
            }

            @using (Html.BeginForm("Register", "Authentication", FormMethod.Post, new { @class = "register-form" }))
            {
                @Html.AntiForgeryToken()
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                    </div>
                }

                <div class="form-grid">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> @LanguageHelper.Translate("FullName")</label>
                        @Html.TextBoxFor(m => m.TKH, new { @class = "form-control", @placeholder = LanguageHelper.Translate("EnterFullName"), @required = "required" })
                        @Html.ValidationMessageFor(m => m.TKH, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-at"></i> Tên đăng nhập</label>
                        @Html.TextBoxFor(m => m.TenDN, new { @class = "form-control", @placeholder = "Nhập tên đăng nhập", @required = "required" })
                        @Html.ValidationMessageFor(m => m.TenDN, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-phone"></i> @LanguageHelper.Translate("PhoneNumber")</label>
                        @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", @placeholder = LanguageHelper.Translate("EnterPhoneNumber"), @type = "tel", @required = "required" })
                        @Html.ValidationMessageFor(m => m.SDT, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-id-card"></i> @LanguageHelper.Translate("IDCard")</label>
                        @Html.TextBoxFor(m => m.CMND_CCCD, new { @class = "form-control", @placeholder = LanguageHelper.Translate("EnterIDCard"), @required = "required" })
                        @Html.ValidationMessageFor(m => m.CMND_CCCD, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group full-width">
                        <label><i class="fas fa-map-marker-alt"></i> @LanguageHelper.Translate("Address")</label>
                        @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", @placeholder = LanguageHelper.Translate("EnterAddress"), @required = "required" })
                        @Html.ValidationMessageFor(m => m.DiaChi, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group full-width">
                        <label><i class="fas fa-envelope"></i> Email</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "Nhập email", @type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Mật khẩu</label>
                        @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control", @placeholder = "Nhập mật khẩu", @required = "required" })
                        @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Nhập lại mật khẩu</label>
                        @Html.PasswordFor(m => m.ConfirmMatKhau, new { @class = "form-control", @placeholder = "Nhập lại mật khẩu", @required = "required" })
                        @Html.ValidationMessageFor(m => m.ConfirmMatKhau, "", new { @class = "field-validation-error" })
                    </div>

                    <div class="form-group full-width">
                        <label><i class="fas fa-shield-alt"></i> @LanguageHelper.Translate("Captcha")</label>
                        <div class="captcha-group">
                            <div class="captcha-image" id="captchaDisplay">
                                @Session["CaptchaCode"]
                            </div>
                            <div class="captcha-input">
                                <input type="text" name="captchaCode" class="form-control" placeholder="@LanguageHelper.Translate("EnterCaptcha")" required />
                            </div>
                            <button type="button" class="refresh-captcha" onclick="refreshCaptcha()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                        @if (ViewData.ModelState["CaptchaCode"] != null && ViewData.ModelState["CaptchaCode"].Errors.Count > 0)
                        {
                            <span class="field-validation-error">@ViewData.ModelState["CaptchaCode"].Errors[0].ErrorMessage</span>
                        }
                    </div>
                </div>

                if (ViewBag.ShowConfirmation == true)
                {
                    <div class="form-group full-width">
                        <label><i class="fas fa-key"></i> Mã xác nhận</label>
                        @Html.TextBoxFor(m => m.ConfirmationCode, new { @class = "form-control", @placeholder = "Nhập mã xác nhận", autocomplete = "off" })
                        @Html.ValidationMessageFor(m => m.ConfirmationCode, "", new { @class = "field-validation-error" })
                        @if (!string.IsNullOrWhiteSpace(ViewBag.ConfirmationMessage))
                        {
                            <small style="display:block;margin-top:8px;color:#065f46;">@ViewBag.ConfirmationMessage</small>
                        }
                    </div>
                }

                <button type="submit" class="btn-register">
                    <i class="fas fa-user-plus"></i> @LanguageHelper.Translate("Register")
                </button>
            }

            <div class="auth-footer">
                <p>@LanguageHelper.Translate("AlreadyHaveAccount") <a href="@Url.Action("Login", "Authentication")">@LanguageHelper.Translate("Login")</a></p>
            </div>
        </div>
    </div>
</div>

<script>
    function refreshCaptcha() {
        window.location.reload();
    }
</script>
