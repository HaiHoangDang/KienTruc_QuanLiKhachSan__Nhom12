@model DKS_HotelManager.Models.ViewModels.ContactCommentPageViewModel
@using DKS_HotelManager.Helpers
@{
    ViewBag.Title = "Bình luận";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hotelOptions = Model.HotelOptions ?? Enumerable.Empty<SelectListItem>();
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, rgba(26, 26, 46, 0.9), rgba(22, 33, 62, 0.9)), url('@Url.Content("~/Images/hotel_1.jpg")');
        background-size: cover;
        background-position: center;
        height: 40vh;
        min-height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        margin: -30px 0 40px 0;
    }

    .contact-hero h1 { font-size: 3.2em; font-weight: 700; color: #d4af37; text-shadow: 3px 3px 15px rgba(0,0,0,0.7); }
    .contact-section { padding: 40px 0 70px; }
    .contact-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 24px; }
    .card { background: #fff; border-radius: 18px; padding: 20px; border: 1px solid #e5e7eb; box-shadow: 0 12px 26px rgba(0,0,0,0.08); }
    .card h2 { margin-top: 0; margin-bottom: 10px; }
    .card p { margin-top: 0; color: #6b7280; }
    .comment-form .form-group { margin-bottom: 14px; }
    .form-control { width: 100%; border-radius: 12px; border: 1px solid #d1d5db; padding: 18px 20px; font-size: 17px; line-height: 1.55; }
    select.form-control { min-height: 60px; }
    .submit-btn { background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%); border: none; color: #fff; padding: 12px 20px; border-radius: 12px; font-weight: 700; cursor: pointer; }
    .comment-list { display: flex; flex-direction: column; gap: 12px; max-height: 520px; overflow-y: auto; }
    .comment-item { border: 1px solid #e5e7eb; border-radius: 14px; padding: 12px; background: #fdfdfd; }
    .comment-meta { display: flex; justify-content: space-between; color: #6b7280; font-size: 13px; }
    .alert { padding: 12px 14px; border-radius: 12px; margin-bottom: 12px; }
    .alert.success { background: #ecfdf3; border: 1px solid #34d399; color: #065f46; }
    .alert.error { background: #fef2f2; border: 1px solid #f87171; color: #991b1b; }
    @@media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
</style>

<div class="contact-hero">
    <h1>Gặp gỡ & Bình luận</h1>
</div>

<div class="contact-section container">
    @if (TempData["AccountSuccess"] != null)
    {
        <div class="alert success">@TempData["AccountSuccess"]</div>
    }
    else if (TempData["AccountError"] != null)
    {
        <div class="alert error">@TempData["AccountError"]</div>
    }

    <div class="contact-grid">
        <div class="card">
            <h2>Gửi bình luận</h2>
            <p>Chia sẻ cảm nhận về chuỗi Luxury Hotels hoặc chọn khách sạn cụ thể.</p>

            @using (Html.BeginForm("Comment", "Home", FormMethod.Post, new { @class = "comment-form" }))
            {
                @Html.AntiForgeryToken()
                <div class="form-group">
                    @Html.Label("Chọn khách sạn (tùy chọn)")
                    @Html.DropDownListFor(m => m.Form.HotelId, hotelOptions, null, new { @class = "form-control" })
                </div>
                <div class="form-group">
                    @Html.Label("Nội dung bình luận")
                    @Html.TextAreaFor(m => m.Form.Content, new { @class = "form-control", rows = 4, placeholder = "Viết cảm nhận của bạn..." })
                    @Html.ValidationMessageFor(m => m.Form.Content, "", new { @class = "text-danger" })
                </div>
                <button type="submit" class="submit-btn"><i class="fas fa-paper-plane"></i> Gửi bình luận</button>
            }
        </div>

        <div class="card">
            <h2>Bình luận mới nhất</h2>
            @if (Model.Comments != null && Model.Comments.Any())
            {
                <div class="comment-list">
                    @foreach (var c in Model.Comments)
                    {
                        <div class="comment-item">
                            <div style="font-weight:700;color:#111827;">@c.CustomerName</div>
                            <div style="color:#374151;margin:6px 0;">@c.Content</div>
                            <div class="comment-meta">
                                <span>@c.HotelName</span>
                                <span>@(c.CreatedAt.HasValue ? c.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "")</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="margin:0;color:#6b7280;">Chưa có bình luận nào.</p>
            }
        </div>
    </div>
</div>
