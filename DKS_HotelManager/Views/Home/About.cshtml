@using DKS_HotelManager.Helpers
@{
    ViewBag.Title = LanguageHelper.Translate("About");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5f5f5;
    }

    .about-hero {
        background: linear-gradient(135deg, rgba(26, 26, 46, 0.9), rgba(22, 33, 62, 0.9)), url('@Url.Content("~/Images/hotel_1.jpg")');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        height: 60vh;
        min-height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        position: relative;
    }

    .about-hero-content h1 {
        font-size: 4.5em;
        font-weight: 700;
        margin-bottom: 20px;
        text-shadow: 3px 3px 15px rgba(0,0,0,0.7);
        color: #d4af37;
        letter-spacing: 3px;
        animation: fadeInUp 1s ease-out;
    }

    .about-hero-content p {
        font-size: 1.5em;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.6);
        animation: fadeInUp 1.2s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .about-section {
        padding: 80px 0;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .section-title {
        text-align: center;
        font-size: 3em;
        color: #1a1a2e;
        margin-bottom: 20px;
        font-weight: 700;
        position: relative;
        padding-bottom: 20px;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 4px;
        background: linear-gradient(90deg, transparent, #d4af37, transparent);
    }

    .section-subtitle {
        text-align: center;
        font-size: 1.2em;
        color: #666;
        margin-bottom: 60px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .about-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        margin-bottom: 80px;
    }

    .about-text {
        font-size: 1.1em;
        line-height: 1.8;
        color: #555;
    }

    .about-text h3 {
        color: #1a1a2e;
        font-size: 2em;
        margin-bottom: 20px;
        font-weight: 700;
    }

    .about-text p {
        margin-bottom: 20px;
    }

    .about-image {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .about-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin-top: 60px;
    }

    .feature-card {
        background: white;
        padding: 40px 30px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        transition: all 0.4s;
        border: 1px solid rgba(212, 175, 55, 0.1);
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(212, 175, 55, 0.2);
        border-color: rgba(212, 175, 55, 0.3);
    }

    .feature-icon {
        font-size: 4em;
        color: #d4af37;
        margin-bottom: 20px;
        display: inline-block;
        transition: transform 0.3s;
    }

    .feature-card:hover .feature-icon {
        transform: scale(1.2) rotate(5deg);
    }

    .feature-card h4 {
        color: #1a1a2e;
        font-size: 1.5em;
        margin-bottom: 15px;
        font-weight: 700;
    }

    .feature-card p {
        color: #666;
        line-height: 1.8;
    }

    .stats-section {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 80px 0;
        color: white;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
        text-align: center;
    }

    .stat-item {
        padding: 20px;
    }

    .stat-number {
        font-size: 4em;
        font-weight: 700;
        color: #d4af37;
        margin-bottom: 10px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.2);
    }

    .stat-label {
        font-size: 1.3em;
        opacity: 0.9;
    }

    .mission-vision {
        background: white;
        padding: 80px 0;
    }

    .mission-vision-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-top: 60px;
    }

    .mission-card, .vision-card {
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
        padding: 50px 40px;
        border-radius: 15px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        border-left: 5px solid #d4af37;
    }

    .mission-card h3, .vision-card h3 {
        color: #1a1a2e;
        font-size: 2.5em;
        margin-bottom: 25px;
        font-weight: 700;
    }

    .mission-card p, .vision-card p {
        color: #555;
        font-size: 1.1em;
        line-height: 1.8;
    }

    .cta-section {
        background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
        padding: 80px 0;
        text-align: center;
        color: white;
    }

    .cta-section h2 {
        font-size: 3em;
        margin-bottom: 20px;
        font-weight: 700;
    }

    .cta-section p {
        font-size: 1.3em;
        margin-bottom: 40px;
        opacity: 0.95;
    }

    .cta-button {
        background: white;
        color: #1a1a2e;
        padding: 15px 50px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.2em;
        display: inline-block;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .cta-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        color: #1a1a2e;
    }

    @@media (max-width: 768px) {
        .about-content, .mission-vision-grid {
            grid-template-columns: 1fr;
        }

        .about-hero-content h1 {
            font-size: 2.5em;
        }

        .section-title {
            font-size: 2em;
        }
    }
</style>

<div class="about-hero">
    <div class="about-hero-content">
        <h1>@LanguageHelper.Translate("AboutUs")</h1>
        <p>@LanguageHelper.Translate("AboutUsSubtitle")</p>
    </div>
</div>

<div class="about-section">
    <div class="container">
        <h2 class="section-title">@LanguageHelper.Translate("WelcomeToLuxuryHotels")</h2>
        <p class="section-subtitle">
            @LanguageHelper.Translate("AboutUsDescription")
        </p>

        <div class="about-content">
            <div class="about-text">
                <h3>@LanguageHelper.Translate("OurStory")</h3>
                <p>
                    @LanguageHelper.Translate("OurStoryDesc1")
                </p>
                <p>
                    @LanguageHelper.Translate("OurStoryDesc2")
                </p>
            </div>
            <div class="about-image">
                <img src="@Url.Content("~/Images/hotel_3.jpg")" alt="Luxury Hotel">
            </div>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🏆</div>
                <h4>@LanguageHelper.Translate("InternationalAwards")</h4>
                <p>@LanguageHelper.Translate("InternationalAwardsDesc")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🌟</div>
                <h4>@LanguageHelper.Translate("FiveStarService")</h4>
                <p>@LanguageHelper.Translate("FiveStarServiceDesc")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🌍</div>
                <h4>@LanguageHelper.Translate("MultipleLocations")</h4>
                <p>@LanguageHelper.Translate("MultipleLocationsDesc")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💎</div>
                <h4>@LanguageHelper.Translate("ModernAmenities")</h4>
                <p>@LanguageHelper.Translate("ModernAmenitiesDesc")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🍽️</div>
                <h4>@LanguageHelper.Translate("DiverseCuisine")</h4>
                <p>@LanguageHelper.Translate("DiverseCuisineDesc")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">❤️</div>
                <h4>@LanguageHelper.Translate("QualityCommitment")</h4>
                <p>@LanguageHelper.Translate("QualityCommitmentDesc")</p>
            </div>
        </div>
    </div>
</div>

<div class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-number">50+</div>
                <div class="stat-label">@LanguageHelper.Translate("HotelsCount")</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">1000+</div>
                <div class="stat-label">@LanguageHelper.Translate("RoomsCount")</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">50K+</div>
                <div class="stat-label">@LanguageHelper.Translate("CustomersCount")</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">98%</div>
                <div class="stat-label">@LanguageHelper.Translate("SatisfactionRate")</div>
            </div>
        </div>
    </div>
</div>

<div class="mission-vision">
    <div class="container">
        <h2 class="section-title">@LanguageHelper.Translate("MissionVision")</h2>
        <div class="mission-vision-grid">
            <div class="mission-card">
                <h3>@LanguageHelper.Translate("Mission")</h3>
                <p>
                    @LanguageHelper.Translate("MissionDesc")
                </p>
            </div>
            <div class="vision-card">
                <h3>@LanguageHelper.Translate("Vision")</h3>
                <p>
                    @LanguageHelper.Translate("VisionDesc")
                </p>
            </div>
        </div>
    </div>
</div>

<div class="cta-section">
    <div class="container">
        <h2>@LanguageHelper.Translate("ReadyToExperience")</h2>
        <p>@LanguageHelper.Translate("ReadyToExperienceDesc")</p>
        <a href="@Url.Action("Index", "Hotel")" class="cta-button">@LanguageHelper.Translate("ExploreHotelsButton")</a>
    </div>
</div>
