</style>

<div class="px-4 pb-16 space-y-10">
    <section class="detail-hero">
        <img src="@Url.Content(Model.HeroImage)" alt="@Model.Name" />
        <div class="detail-hero__overlay">
            <p class="hero-kicker">@highlightRoomType</p>
            <h1>@Model.Name</h1>
            <p class="text-sm uppercase tracking-[0.4em]">@Model.Location</p>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="mt-4 max-w-2xl text-white/80">@Model.Description</p>
            }
        </div>
    </section>

    <div class="detail-slider" id="detailSlider">
        <button type="button" class="slider-arrow" id="detailSliderPrev"><i class="fas fa-chevron-left"></i></button>
        <div class="detail-slider__image">
            <img id="detailSliderImage" src="@detailSliderImages.FirstOrDefault()" alt="Room slide" />
            <div class="detail-slider__caption">
                <p>Phòng tiêu biểu</p>
                <strong>@Model.Name</strong>
            </div>
        </div>
        <button type="button" class="slider-arrow" id="detailSliderNext"><i class="fas fa-chevron-right"></i></button>
    </div>

    <div class="detail-info-grid">
        <div class="info-card">
            <span>Nhận phòng</span>
            <strong>@FormatDate(Model.CheckIn)</strong>
        </div>
        <div class="info-card">
            <span>Trả phòng</span>
            <strong>@FormatDate(Model.CheckOut)</strong>
        </div>
        <div class="info-card">
            <span>Khách</span>
            <strong>@Model.Guests khách</strong>
        </div>
        <div class="info-card">
            <span>Giá tham khảo</span>
            <strong>@FormatCurrency(Model.MinAvailablePrice)</strong>
            <small>~ @FormatCurrency(Model.MaxAvailablePrice)</small>
        </div>
    </div>

    <div class="detail-layout">
        <div class="summary-card">
            <p class="text-xs uppercase tracking-[0.4em] text-slate-500">Trải nghiệm</p>
            <h2 class="summary-card__title">Chi tiết phòng & quyền lợi</h2>
            <p class="text-slate-600">@Model.Description</p>

            @if (Model.GalleryImages != null && Model.GalleryImages.Any())
            {
                <div class="gallery-row">
                    @foreach (var image in Model.GalleryImages)
                    {
                        <div class="gallery-card">
                            <img src="@Url.Content(image)" alt="@Model.Name" />
                        </div>
                    }
                </div>
            }

            @foreach (var room in roomsList)
            {
                var roomImagePath = !string.IsNullOrWhiteSpace(room.ImageUrl)
                    ? ResolveImagePath(room.ImageUrl)
                    : ResolveImagePath(null);
                var roomAmenities = room.Amenities != null && room.Amenities.Any()
                    ? string.Join(" • ", room.Amenities)
                    : null;
                <div class="room-card" data-room-id="@room.RoomId" tabindex="0">
                    <div class="room-card__image">
                        <img src="@Url.Content(roomImagePath)" alt="@room.Name" />
                    </div>
                    <div class="room-card__details">
                        <h4>@room.Name</h4>
                        <p class="room-card__meta">
                            <span>@(string.IsNullOrWhiteSpace(room.RoomType) ? "Phòng tiêu biểu" : room.RoomType)</span>
                            @if (room.PricePerNight > 0)
                            {
                                <span class="room-card__meta-dot">•</span>
                                <span>@FormatCurrency(room.PricePerNight)</span>
                            }
                        </p>
                        <p class="room-card__desc">@(!string.IsNullOrWhiteSpace(room.Description) ? room.Description : "Phòng tiêu chuẩn hiện đại.")</p>
                        @if (!string.IsNullOrWhiteSpace(roomAmenities))
                        {
                            <p class="room-card__amenities">@roomAmenities</p>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="details-right">
            <div class="room-highlight-card">
                <img id="selectedRoomImage" src="@Url.Content(highlightRoomImagePath)" alt="Room highlight" />
                <div>
                    <strong id="selectedRoomName">@highlightRoomName</strong>
                    <p class="room-highlight-card__meta">
                        <span id="selectedRoomType">@highlightRoomType</span>
                        <span class="room-highlight-card__meta-dot">•</span>
                        <span id="selectedRoomCapacity">@highlightRoomCapacity</span>
                        <span class="room-highlight-card__meta-dot">•</span>
                        <span id="selectedRoomArea">@highlightRoomArea</span>
                    </p>
                    <p class="room-highlight-card__price" id="selectedRoomPrice">@highlightRoomPrice</p>
                    <p class="text-sm text-slate-500" id="selectedRoomDescription">@highlightRoomDescription</p>
                    <p class="mt-3 text-xs uppercase tracking-[0.3em] text-slate-400">Bao gồm</p>
                    <p class="text-slate-600 text-sm" id="selectedRoomAmenities">@highlightAmenitiesText</p>
                </div>
            </div>

            <aside class="booking-card">
            <p class="booking-card__label">Đặt phòng ưu đãi</p>
            <p class="booking-card__price" id="bookingCardPrice">@highlightRoomPrice</p>
            <p class="text-slate-500 mb-4 text-sm" id="bookingCardSubtitle">
                @if (highlightRoom != null)
                {
                    <text>Giá mỗi đêm cho @highlightRoomName</text>
                }
                else
                {
                    <text>Liên hệ để biết giá phòng</text>
                }
            </p>
            <div class="booking-card__info-grid">
                <div class="booking-card__info-block">
                    <span>Nhận phòng</span>
                    <strong>@FormatDate(Model.CheckIn)</strong>
                </div>
                <div class="booking-card__info-block">
                    <span>Trả phòng</span>
                    <strong>@FormatDate(Model.CheckOut)</strong>
                </div>
                <div class="booking-card__info-block">
                    <span>Khách</span>
                    <strong>@bookingGuests khách</strong>
                </div>
                <div class="booking-card__info-block">
                    <span>Phòng cần</span>
                    <strong>@totalRooms lựa chọn</strong>
                </div>
            </div>
            <a class="booking-card__button" href="@bookingLink" role="button" id="bookingCardButton">
                Đặt ngay
            </a>
                <div class="booking-card__meta">
                    <p class="booking-card__meta-title">Dịch vụ nổi bật</p>
                <ul id="bookingCardServiceList">
                    @if (highlightRoomServices.Any())
                    {
                        foreach (var service in highlightRoomServices)
                        {
                            <li><i class="fas fa-check-circle"></i> @service</li>
                        }
                    }
                    else
                    {
                        <li class="text-slate-500 italic">Chưa có dịch vụ nào được cập nhật.</li>
                    }
                </ul>
            </div>
        </aside>
        </div>
    </div>
    <section class="comments-section">
        <h3>Đánh giá khách hàng</h3>
        <div class="comments-grid">
            @if (Model.Comments != null && Model.Comments.Any())
            {
                foreach (var comment in Model.Comments)
                {
                    <article class="comment-card">
                        <div class="comment-meta">
                            @{
                                var metaParts = new List<string>();
                                if (!string.IsNullOrWhiteSpace(comment.CustomerName))
                                {
                                    metaParts.Add(comment.CustomerName.ToUpperInvariant());
                                }
                                if (!string.IsNullOrWhiteSpace(comment.RoomName))
                                {
                                    metaParts.Add(comment.RoomName.ToUpperInvariant());
                                }
                                if (comment.CreatedAt.HasValue)
                                {
                                    metaParts.Add(comment.CreatedAt.Value.ToString("dd/MM/yyyy"));
                                }
                                <text>@string.Join(" • ", metaParts)</text>
                            }
                        </div>
                        <p class="comment-body">@comment.Content</p>
                    </article>
                }
            }
            else
            {
                <div class="comment-card">
                    <p class="comment-body">Chưa có đánh giá nào, hãy là người đầu tiên chia sẻ cảm nhận của bạn.</p>
                </div>
            }
        </div>
    </section>
    @if (Model.SimilarRooms != null && Model.SimilarRooms.Any())
    {
        <section class="similar-rooms-section">
            <p class="similar-rooms-title">Phòng có giá tương đương</p>
            <div class="similar-rooms-grid">
                @foreach (var similar in Model.SimilarRooms)
                {
                    var similarImage = ResolveImagePath(similar.ImageUrl);
                    var similarAmenities = similar.Amenities != null && similar.Amenities.Any()
                        ? string.Join(" • ", similar.Amenities.Take(3))
                        : "Tiện nghi đẳng cấp";
                    <article class="similar-card" data-room-id="@similar.RoomId">
                        <a class="similar-card__link" href="@Url.Action("Details", "Hotel", new { id = similar.HotelId })">
                            <div class="similar-card__image">
                                <img src="@Url.Content(similarImage)" alt="@similar.Name" />
                            </div>
                            <div class="similar-card__details">
                                <h4>@similar.Name</h4>
                                <p class="similar-card__meta">@(!string.IsNullOrWhiteSpace(similar.RoomType) ? similar.RoomType : "Phòng tiêu biểu")</p>
                                <p class="similar-card__price">@FormatCurrency(similar.PricePerNight)</p>
                                <p class="similar-card__amenities">@similarAmenities</p>
                            </div>
                        </a>
                    </article>
                }
            </div>
        </section>
    }
</div>

<script>
    (function () {
        const slides = @Html.Raw(Json.Encode(detailSliderImages));
        if (!slides || slides.length === 0) {
            return;
        }

        let pointer = 0;
        const sliderImage = document.getElementById('detailSliderImage');
        const nextBtn = document.getElementById('detailSliderNext');
        const prevBtn = document.getElementById('detailSliderPrev');

        function showSlide(idx) {
            sliderImage.src = slides[idx];
        }

        nextBtn?.addEventListener('click', function () {
            pointer = (pointer + 1) % slides.length;
            showSlide(pointer);
        });

        prevBtn?.addEventListener('click', function () {
            pointer = (pointer - 1 + slides.length) % slides.length;
            showSlide(pointer);
        });

        setInterval(function () {
            pointer = (pointer + 1) % slides.length;
            showSlide(pointer);
        }, 4000);
    })();
</script>

<script>
    (function () {
        const roomsData = @Html.Raw(string.IsNullOrWhiteSpace(roomsJson) ? "[]" : roomsJson);
        if (!roomsData || roomsData.length === 0) {
            return;
        }

        const summaryImage = document.getElementById('selectedRoomImage');
        const summaryName = document.getElementById('selectedRoomName');
        const summaryType = document.getElementById('selectedRoomType');
        const summaryCapacity = document.getElementById('selectedRoomCapacity');
        const summaryArea = document.getElementById('selectedRoomArea');
        const summaryPrice = document.getElementById('selectedRoomPrice');
        const summaryDescription = document.getElementById('selectedRoomDescription');
        const summaryAmenities = document.getElementById('selectedRoomAmenities');
        const bookingCardPrice = document.getElementById('bookingCardPrice');
        const bookingCardSubtitle = document.getElementById('bookingCardSubtitle');
        const bookingButton = document.getElementById('bookingCardButton');
        const bookingServiceList = document.getElementById('bookingCardServiceList');
        const roomCards = Array.from(document.querySelectorAll('.room-card[data-room-id]'));
        if (!roomCards.length) {
            return;
        }

        const priceFormatter = new Intl.NumberFormat('vi-VN');
        const checkInDate = @Html.Raw(Json.Encode(checkInDate));
        const checkOutDate = @Html.Raw(Json.Encode(checkOutDate));
        const bookingGuestsValue = @bookingGuests;
        const baseBookingUrl = @Html.Raw(Json.Encode(baseBookingUrl));
        const baseParams = new URLSearchParams();
        if (checkInDate) {
            baseParams.set('checkIn', checkInDate);
        }
        if (checkOutDate) {
            baseParams.set('checkOut', checkOutDate);
        }
        if (bookingGuestsValue) {
            baseParams.set('guests', bookingGuestsValue);
        }

        const formatPrice = (value) => {
            if (value === null || value === undefined) {
                return 'Liên hệ';
            }
            return priceFormatter.format(value) + ' ₫';
        };

        const buildBookingHref = (roomId) => {
            const params = new URLSearchParams(baseParams);
            params.set('roomId', roomId);
            return `${baseBookingUrl}?${params.toString()}`;
        };

        const renderServiceList = (items) => {
            if (!bookingServiceList) {
                return;
            }
            bookingServiceList.innerHTML = '';
            if (items && items.length) {
                items.forEach(item => {
                    const li = document.createElement('li');
                    li.innerHTML = `<i class="fas fa-check-circle"></i> ${item}`;
                    bookingServiceList.appendChild(li);
                });
                return;
            }
            const fallback = document.createElement('li');
            fallback.className = 'text-slate-500 italic';
            fallback.textContent = 'Chưa có dịch vụ nào được cập nhật.';
            bookingServiceList.appendChild(fallback);
        };

        const activateRoom = (roomId) => {
            const room = roomsData.find(r => r.RoomId === roomId);
            if (!room) {
                return;
            }

            if (summaryImage) {
                summaryImage.src = room.ImageUrl || summaryImage.getAttribute('src');
            }
            if (summaryName) {
                summaryName.textContent = room.Name || 'Phòng';
            }
            if (summaryType) {
                summaryType.textContent = room.RoomType || 'Phòng tiêu biểu';
            }
            if (summaryCapacity) {
                summaryCapacity.textContent = room.Capacity ? `${room.Capacity} khách` : 'Chưa rõ';
            }
            if (summaryArea) {
                summaryArea.textContent = room.Area ? `${room.Area.toLocaleString('vi-VN')} m²` : 'Chưa rõ';
            }
            if (summaryPrice) {
                summaryPrice.textContent = formatPrice(room.PricePerNight);
            }
            if (summaryDescription) {
                summaryDescription.textContent = room.Description || 'Phòng được lựa chọn với tiện nghi chuẩn quốc tế.';
            }
            if (summaryAmenities) {
                summaryAmenities.textContent = room.Amenities && room.Amenities.length > 0
                    ? room.Amenities.slice(0, 4).join(' • ')
                    : 'Tiện nghi đẳng cấp và hiện đại';
            }
            if (bookingCardPrice) {
                bookingCardPrice.textContent = formatPrice(room.PricePerNight);
            }
            if (bookingCardSubtitle) {
                const roomLabel = room.Name || room.RoomType || 'phòng';
                bookingCardSubtitle.textContent = `Giá mỗi đêm cho ${roomLabel}`;
            }
            if (bookingButton) {
                bookingButton.href = buildBookingHref(roomId);
            }
            renderServiceList(room.Amenities);
            roomCards.forEach(card => {
                const isActive = String(card.dataset.roomId) === String(roomId);
                card.classList.toggle('active', isActive);
            });
        };

        roomCards.forEach(card => {
            const roomId = parseInt(card.dataset.roomId, 10);
            card.addEventListener('click', () => activateRoom(roomId));
            card.addEventListener('keypress', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    activateRoom(roomId);
                }
            });
        });

        activateRoom(parseInt(roomCards[0].dataset.roomId, 10));
    })();
</script>

