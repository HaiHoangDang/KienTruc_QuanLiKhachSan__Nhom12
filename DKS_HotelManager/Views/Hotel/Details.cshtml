@model DKS_HotelManager.Models.ViewModels.HotelDetailViewModel
@using System.Globalization
@using System.Linq
@using System.Collections.Generic
@using DKS_HotelManager.Models.ViewModels
@using DKS_HotelManager.Helpers
@using System.Web.Helpers
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@functions {
    private string FormatCurrency(decimal value)
    {
        return value.ToString("N0", new CultureInfo("vi-VN")) + " ₫";
    }

    private string FormatArea(double area)
    {
        return area > 0 ? string.Format("{0:N0} m²", area) : "Không rõ";
    }

    private string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd MMM yyyy") : "Chưa chọn";
    }

    private string ResolveImagePath(string path, bool isHotelImage = false)
    {
        var resolved = RoomImageHelper.ResolveRoomImagePath(path);
        if (!string.IsNullOrWhiteSpace(resolved))
        {
            return resolved;
        }

        return isHotelImage ? "~/Images/ks01.jpg" : "~/Images/hotel_1.jpg";
    }
}

@{
    var detailSliderImages = (Model.GalleryImages ?? Enumerable.Empty<string>())
        .Select(img => Url.Content(img))
        .ToList();

    var roomsList = Model.Rooms ?? new List<HotelRoomViewModel>();
    var highlightRoom = roomsList.FirstOrDefault();
    var highlightRoomName = highlightRoom != null && !string.IsNullOrWhiteSpace(highlightRoom.Name)
        ? highlightRoom.Name
        : (highlightRoom != null && !string.IsNullOrWhiteSpace(highlightRoom.RoomType) ? highlightRoom.RoomType : "Phòng đặc biệt");
    var highlightRoomType = highlightRoom != null && !string.IsNullOrWhiteSpace(highlightRoom.RoomType)
        ? highlightRoom.RoomType
        : "Phòng tiêu biểu";
    var highlightRoomDescription = highlightRoom != null && !string.IsNullOrWhiteSpace(highlightRoom.Description)
        ? highlightRoom.Description
        : "Phòng được lựa chọn với tiện nghi chuẩn quốc tế.";
    var highlightRoomImagePath = ResolveImagePath(highlightRoom != null ? highlightRoom.ImageUrl : Model.HeroImage);
    var highlightAmenitiesText = highlightRoom != null && highlightRoom.Amenities != null && highlightRoom.Amenities.Any()
        ? string.Join(" • ", highlightRoom.Amenities.Take(4))
        : "Tiện nghi đẳng cấp và hiện đại";
    var highlightRoomPrice = highlightRoom != null ? FormatCurrency(highlightRoom.PricePerNight) : "Liên hệ";
    var highlightRoomCapacity = highlightRoom != null ? string.Format("{0} khách", highlightRoom.Capacity) : "Chưa rõ";
    var highlightRoomArea = highlightRoom != null ? FormatArea(highlightRoom.Area) : "Chưa rõ";
    var totalRooms = roomsList.Count;

    if (!detailSliderImages.Any())
    {
        detailSliderImages.Add(Url.Content(Model.HeroImage));
    }

    var firstRoom = highlightRoom;
    int? bookingRoomId;
    if (Model.BookingForm != null && Model.BookingForm.RoomId.HasValue)
    {
        bookingRoomId = Model.BookingForm.RoomId;
    }
    else
    {
        bookingRoomId = firstRoom != null ? firstRoom.RoomId : (int?)null;
    }

    var bookingGuests = (Model.BookingForm != null && Model.BookingForm.Guests > 0)
        ? Model.BookingForm.Guests
        : (Model.Guests > 0 ? Model.Guests : 1);

    string checkInDate = null;
    string checkOutDate = null;
    if (Model.CheckIn.HasValue)
    {
        checkInDate = Model.CheckIn.Value.ToString("yyyy-MM-dd");
    }
    if (Model.CheckOut.HasValue)
    {
        checkOutDate = Model.CheckOut.Value.ToString("yyyy-MM-dd");
    }

    var bookingLink = Url.Action("Book", "Hotel", new
    {
        id = Model.HotelId,
        roomId = bookingRoomId,
        checkIn = checkInDate,
        checkOut = checkOutDate,
        guests = bookingGuests
    });
    var baseBookingUrl = Url.Action("Book", "Hotel", new { id = Model.HotelId });
    var highlightRoomServices = (highlightRoom != null && highlightRoom.Amenities != null)
        ? highlightRoom.Amenities.ToList()
        : new List<string>();
    var roomScriptData = roomsList.Select(r => new
    {
        r.RoomId,
        r.Name,
        r.RoomType,
        ImageUrl = Url.Content(!string.IsNullOrWhiteSpace(r.ImageUrl) ? r.ImageUrl : "~/Images/no_image.jpg"),
        r.PricePerNight,
        r.Capacity,
        r.Area,
        r.Description,
        Amenities = r.Amenities ?? new List<string>()
    }).ToList();
    var roomsJson = Json.Encode(roomScriptData);
}

