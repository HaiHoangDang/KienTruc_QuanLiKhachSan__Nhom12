@model DKS_HotelManager.Areas.Admin.ViewModels.DashboardSummaryViewModel
@using System.Linq
@using System.Web.Helpers
@{
    var adminName = Session["AdminName"] as string ?? "Quản trị";
}

<style>
    .admin-hero {
        border-radius: 26px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(30, 64, 175, 0.25));
        padding: 32px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-bottom: 30px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.65);
    }

    .hero-content h1 {
        margin: 8px 0;
        font-size: clamp(2rem, 3vw, 2.4rem);
        letter-spacing: 0.05em;
    }

    .hero-sum {
        color: rgba(248, 250, 255, 0.8);
        margin-bottom: 20px;
        font-size: 1rem;
        max-width: 520px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .hero-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        background: rgba(255, 255, 255, 0.04);
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s ease, border 0.2s ease, background 0.2s ease;
    }

    .hero-button.primary {
        background: linear-gradient(135deg, #38bdf8, #2563eb);
        border-color: transparent;
        box-shadow: 0 6px 18px rgba(37, 99, 235, 0.4);
    }

    .hero-button:hover {
        transform: translateY(-2px);
    }

    .hero-metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(140px, 1fr));
        gap: 12px;
    }

    .metric-box {
        border-radius: 16px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        text-align: center;
    }

    .metric-value {
        font-size: 1.8rem;
        font-weight: 700;
        display: block;
        color: #e2e8f0;
    }

        .metric-label {
            font-size: 0.85rem;
            letter-spacing: 0.3em;
            color: rgba(248, 250, 255, 0.6);
            text-transform: uppercase;
        }

    .hero-pretitle,
    .hero-content h1,
    .hero-sum,
    .hero-actions a,
    .metric-value,
    .metric-label {
        font-size: 1.25rem;
    }

    .admin-section {
        margin-bottom: 24px;
    }
    
    .overview-note {
        color: rgba(248, 250, 255, 0.7);
    }
</style>

<section class="admin-hero">
    <div class="hero-content">
        <p class="hero-pretitle">Xin chào, Quản Trị</p>
        <h1>@adminName</h1>
        <p class="hero-sum">Tập trung vào các số liệu chính, kiểm soát doanh thu và điều phối nhân sự trên một bảng điều khiển.</p>
        <div class="hero-actions">
            <a href="@Url.Action("Index", "Hotels", new { area = "Admin" })" class="hero-button primary">
                <i class="fas fa-building"></i> Quản lý cơ sở
            </a>
            <a href="@Url.Action("Index", "Staff", new { area = "Admin" })" class="hero-button">
                <i class="fas fa-user-tie"></i> Nhân sự
            </a>
            <a href="@Url.Action("Index", "Revenue", new { area = "Admin" })" class="hero-button">
                <i class="fas fa-wallet"></i> Dòng tiền
            </a>
        </div>
    </div>
    <div class="hero-metrics">
        <div class="metric-box">
            <span class="metric-value">@Model.HotelCount</span>
            <span class="metric-label">Khách sạn</span>
        </div>
        <div class="metric-box">
            <span class="metric-value">@Model.RoomCount</span>
            <span class="metric-label">Phòng</span>
        </div>
        <div class="metric-box">
            <span class="metric-value">@Model.ServiceCount</span>
            <span class="metric-label">Dịch vụ</span>
        </div>
        <div class="metric-box">
            <span class="metric-value">@Model.EmployeeCount</span>
            <span class="metric-label">Nhân viên</span>
        </div>
    </div>
</section>

<section class="admin-section">
    <div class="section-header">
        <div>
            <h2>Doanh thu 6 tháng gần nhất</h2>
            <small class="overview-note">Dựa trên hóa đơn thanh toán đã ghi nhận.</small>
        </div>
        <div class="revenue-chip">@String.Format("{0:N0} VND", Model.TotalRevenue)</div>
    </div>
    <div class="revenue-card">
        <canvas id="summaryRevenueChart" height="160"></canvas>
    </div>
</section>

<section class="admin-section">
    <div class="section-header">
        <div>
            <h2>Lịch sử đăng nhập và thao tác nhân viên</h2>
            <small class="overview-note">Admin theo dõi nhanh các phiên và hoạt động mới nhất.</small>
        </div>
    </div>
    <div class="table-panel">
        <div class="table-wrapper">
            @if (!Model.StaffActivities.Any())
            {
                <p class="overview-note">Chưa có thông tin đăng nhập nào được ghi nhận.</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Thời điểm</th>
                            <th>Nhân viên</th>
                            <th>Sự kiện</th>
                            <th>Chi nhánh</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.StaffActivities)
                        {
                            <tr>
                                <td>@log.Timestamp.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</td>
                                <td>@(string.IsNullOrWhiteSpace(log.StaffName) ? "Không rõ" : log.StaffName)</td>
                                <td>@log.Event</td>
                                <td>@(string.IsNullOrWhiteSpace(log.HotelName) ? "Chưa chọn" : log.HotelName)</td>
                                <td>@(string.IsNullOrWhiteSpace(log.Details) ? "-" : log.Details)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>

@section scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const summaryLabels = @Html.Raw(Json.Encode(Model.RevenueSeries.Select(r => r.Label)));
        const summaryValues = @Html.Raw(Json.Encode(Model.RevenueSeries.Select(r => r.Value)));
        const summaryCtx = document.getElementById('summaryRevenueChart');
        if (summaryCtx) {
            new Chart(summaryCtx, {
                type: 'line',
                data: {
                    labels: summaryLabels,
                    datasets: [{
                        label: 'Doanh thu (VND)',
                        data: summaryValues,
                        fill: true,
                        backgroundColor: 'rgba(212, 175, 55, 0.2)',
                        borderColor: '#d4af37',
                        tension: 0.3
                    }]
                },
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function (value) {
                                    return value.toLocaleString() + ' đ';
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.dataset.label + ': ' + context.parsed.y.toLocaleString() + ' đ';
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
}
