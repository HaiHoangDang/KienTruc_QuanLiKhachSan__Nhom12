@model DKS_HotelManager.Areas.Admin.ViewModels.CommentsPageViewModel

<section class="admin-section">
    <div class="section-header">
        <div>
            <h2>Quản lý bình luận</h2>
            <small class="overview-note">Duyệt, sửa hoặc xóa bình luận từ khách hàng.</small>
        </div>
    </div>

    <div class="management-grid">


        <div class="table-panel">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th style="width:15%;">Khách hàng</th>
                            <th style="width:15%;">Khách sạn</th>
                            <th style="width:10%;">Phòng</th>
                            <th style="width:10%;">Ngày</th>
                            <th style="width:30%;">Nội dung</th>
                            <th style="width:20%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Comments != null && Model.Comments.Any())
                        {
                            foreach (var comment in Model.Comments)
                            {
                                <tr>
                                    <td class="text-nowrap">@comment.CustomerName</td>
                                    <td class="text-nowrap">@comment.HotelName</td>
                                    <td class="text-nowrap">@comment.RoomName</td>
                                    <td class="text-nowrap">@(comment.CreatedAt.HasValue ? comment.CreatedAt.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td>
                                        @(comment.Content != null && comment.Content.Length > 50 ? comment.Content.Substring(0, 50) + "..." : comment.Content)
                                    </td>
                                    <td>
                                        <button type="button" class="btn-link btn-edit-comment"
                                                data-id="@comment.MaBL"
                                                data-customer="@comment.MKH"
                                                data-hotel="@(comment.MaKS ?? 0)"
                                                data-room="@(comment.MaPhong ?? 0)"
                                                data-content="@Html.AttributeEncode(comment.Content ?? "")"
                                                data-date="@(comment.CreatedAt.HasValue ? comment.CreatedAt.Value.ToString("yyyy-MM-dd") : "")">
                                            <i class="fas fa-edit"></i> Sửa
                                        </button>
                                        <form method="post" action="@Url.Action("DeleteComment", "Comments", new { area = "Admin" })" class="inline-form" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maBL" value="@comment.MaBL" />
                                            <button type="submit" class="btn-link text-danger">
                                                <i class="fas fa-trash-alt"></i> Xóa
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center-placeholder">Không có bình luận nào để hiển thị.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="form-panel">
            <h3 id="formTitle">Thêm mới Bình luận</h3>
            <form id="commentForm" method="post" action="@Url.Action("SaveComment", "Comments", new { area = "Admin" })">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MaBL" id="commentId" value="0" />

                <label for="commentCustomer">Khách hàng <span class="required-star">*</span></label>
                <select id="commentCustomer" name="MKH" required>
                    <option value="">Chọn khách hàng</option>
                    @foreach (var option in Model.CustomerOptions)
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                </select>

                <label for="commentHotel">Khách sạn</label>
                <select id="commentHotel" name="MaKS">
                    <option value="">Chọn khách sạn</option>
                    @foreach (var option in Model.HotelOptions)
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                </select>

                <label for="commentRoom">Phòng</label>
                <select id="commentRoom" name="MaPhong">
                    <option value="">Chọn phòng</option>
                    @foreach (var option in Model.RoomOptions)
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                </select>

                <label for="commentContent">Nội dung <span class="required-star">*</span></label>
                <textarea id="commentContent" name="NoiDung" rows="4" required></textarea>

                <label for="commentDate">Ngày bình luận</label>
                <input id="commentDate" name="NgayBL" type="date" />

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" id="resetCommentForm">
                        <i class="fas fa-undo"></i> Làm mới
                    </button>
                    <button type="submit" class="btn-luxury" id="saveCommentBtn">
                        <i class="fas fa-save"></i> Lưu bình luận
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<style>
    /* Lưu ý: Các biến CSS như --primary, --text, --border, v.v. cần được định nghĩa trong _Layout.cshtml của bạn */

    /* ==================================== */
    /* PHẦN CHUNG CỦA TRANG */
    /* ==================================== */
    .admin-section {
        margin-bottom: 40px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 30px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 15px;
    }

        .section-header h2 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 5px;
        }

        .section-header .overview-note {
            font-size: 1rem; /* Đã tăng font */
            color: var(--text-muted);
        }

    .management-grid {
        display: grid;
        /* ĐÃ CHỈNH SỬA: Tỷ lệ 3fr (rộng hơn) cho bảng (trái), 1.2fr cho form (phải) */
        grid-template-columns: 3fr 1.2fr;
        gap: 30px;
    }

    /* ==================================== */
    /* TABLE PANEL - Tăng font chữ */
    /* ==================================== */
    .table-panel {
        background: var(--surface);
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 24px;
        box-shadow: 0 15px 30px rgba(2, 6, 23, 0.55);
        overflow-x: auto;
    }

    .table-wrapper {
        width: 100%;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        color: var(--text);
        min-width: 750px;
    }

        table thead {
            background: rgba(255, 255, 255, 0.06);
        }

        table th {
            font-weight: 600;
            text-align: left;
            padding: 14px 18px;
            font-size: 0.95rem; /* Đã tăng font */
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        table td {
            padding: 14px 18px; /* Đã tăng padding */
            border-bottom: 1px solid var(--border);
            font-size: 1rem; /* ĐÃ TĂNG FONT CỠ CHUẨN */
            color: var(--text);
            vertical-align: top;
        }

        table tbody tr:last-child td {
            border-bottom: none;
        }

        table tbody tr:hover {
            background-color: rgba(56, 189, 248, 0.05);
        }

    .text-center-placeholder {
        text-align: center;
        color: var(--text-muted);
        font-style: italic;
        padding: 30px 18px !important;
    }

    .text-nowrap {
        white-space: nowrap;
    }

    /* ==================================== */
    /* FORM PANEL - Tăng font chữ và tối ưu */
    /* ==================================== */
    .form-panel {
        background: var(--surface);
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 24px;
        box-shadow: 0 15px 30px rgba(2, 6, 23, 0.55);
        display: flex;
        flex-direction: column;
        gap: 0;
    }

        .form-panel h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 20px;
        }

        .form-panel form {
            display: flex;
            flex-direction: column;
        }

    .required-star {
        color: var(--danger);
        font-weight: 700;
        margin-left: 2px;
    }

    .form-panel label {
        font-weight: 600;
        display: block;
        margin-bottom: 6px;
        font-size: 15px; /* ĐÃ TĂNG FONT */
        color: var(--text-muted);
        letter-spacing: 0.02em;
        margin-top: 15px;
    }

    .form-panel form label:first-of-type {
        margin-top: 0;
    }

    .form-panel input[type="text"],
    .form-panel input[type="date"],
    .form-panel select,
    .form-panel textarea {
        width: 100%;
        border: 1px solid var(--border);
        background: var(--surface-alt);
        color: var(--text);
        border-radius: 12px;
        padding: 12px 14px; /* ĐÃ TĂNG PADDING */
        font-size: 16px; /* ĐÃ TĂNG FONT CỠ CHUẨN */
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        appearance: none;
    }

        .form-panel input[type="text"]:focus,
        .form-panel input[type="date"]:focus,
        .form-panel select:focus,
        .form-panel textarea:focus {
            border-color: var(--primary);
            background: rgba(56, 189, 248, 0.1);
            outline: none;
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
        }

    .form-panel textarea {
        resize: vertical;
        min-height: 80px;
        padding: 14px;
    }

    /* Custom style cho select */
    .form-panel select {
        background-repeat: no-repeat;
        background-position: right 14px center;
        background-size: 1.2em;
        padding-right: 2.5em;
    }

    /* ==================================== */
    /* FORM ACTIONS & BUTTONS */
    /* ==================================== */
    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        justify-content: flex-end;
    }

    /* Nút chính (Lưu bình luận) */
    .btn-luxury {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--primary);
        color: var(--bg);
        padding: 12px 22px; /* ĐÃ TĂNG PADDING */
        border-radius: 12px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        min-width: 120px;
    }

        .btn-luxury:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, var(--accent-strong), #0ea5e9);
            box-shadow: 0 8px 18px rgba(56, 189, 248, 0.35);
        }

    /* Nút Cảnh báo/Cập nhật (Màu Cam) */
    .btn-warn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--warn, #f4a261);
        color: var(--bg);
        padding: 12px 22px;
        border-radius: 12px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        min-width: 120px;
    }

        .btn-warn:hover {
            transform: translateY(-2px);
            background: #e77e38;
            box-shadow: 0 8px 18px rgba(244, 162, 97, 0.4);
        }

    /* Nút phụ (Làm mới) */
    .btn.btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--surface-alt);
        color: var(--text-muted);
        padding: 12px 22px; /* ĐÃ TĂNG PADDING */
        border-radius: 12px;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        font-weight: 600;
        min-width: 100px;
    }

        .btn.btn-secondary:hover {
            background: rgba(255, 255, 255, 0.08);
            color: var(--text);
            border-color: rgba(255, 255, 255, 0.15);
        }

    /* Nút hành động trong bảng (Sửa, Xóa) */
    .btn-link {
        background: none;
        border: none;
        padding: 6px 8px;
        font-size: 1rem; /* ĐÃ TĂNG FONT */
        font-weight: 500;
        color: var(--accent);
        cursor: pointer;
        transition: color 0.2s ease, text-decoration 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

        .btn-link:hover {
            text-decoration: underline;
            color: var(--accent-strong);
        }

        .btn-link.text-danger {
            color: var(--danger, #ef4444);
        }

            .btn-link.text-danger:hover {
                color: var(--warn, #f4a261);
            }

    .inline-form {
        display: inline-block;
        margin-left: 8px;
    }

    /* ==================================== */
    /* RESPONSIVE */
    /* ==================================== */
    @@media (max-width: 992px) {
        .management-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@section scripts
{
    <script>
        $(function () {

            // Khởi tạo tiêu đề form lần đầu
            $('#formTitle').text('Thêm mới Bình luận');

            // Xử lý sự kiện nút Làm mới (Reset)
            $('#resetCommentForm').on('click', function () {
                $('#commentId').val(0);
                $('#commentForm')[0].reset();
                // Đổi nút về trạng thái Lưu
                $('#saveCommentBtn').html('<i class="fas fa-save"></i> Lưu bình luận')
                    .removeClass('btn-warn')
                    .addClass('btn-luxury');
                // Đổi tiêu đề form về trạng thái Thêm mới
                $('#formTitle').text('Thêm mới Bình luận');
            });

            // Xử lý sự kiện nút Sửa
            $('.btn-edit-comment').on('click', function () {
                var btn = $(this);

                // Đổ dữ liệu vào Form
                $('#commentId').val(btn.data('id'));
                $('#commentCustomer').val(btn.data('customer'));
                $('#commentHotel').val(btn.data('hotel'));
                $('#commentRoom').val(btn.data('room'));
                $('#commentContent').val(btn.data('content'));
                $('#commentDate').val(btn.data('date'));

                // Cập nhật nút thành Cập nhật (Màu Cam/Warn)
                $('#saveCommentBtn').html('<i class="fas fa-sync-alt"></i> Cập nhật')
                    .removeClass('btn-luxury')
                    .addClass('btn-warn');

                // Cập nhật tiêu đề Form
                $('#formTitle').text('Cập nhật Bình luận (ID: ' + btn.data('id') + ')');

                // Cuộn lên form để người dùng tiện chỉnh sửa
                $('html, body').animate({
                    scrollTop: $(".form-panel").offset().top - 20
                }, 500);
            });
        });
    </script>
}