@model DKS_HotelManager.Areas.Admin.ViewModels.HotelsPageViewModel

<section class="admin-section">
    <div class="section-header">
        <div>
            <h2>Quản lý khách sạn</h2>
            <small class="overview-note">Thêm mới hoặc chỉnh sửa khách sạn và mô tả.</small>
        </div>
    </div>

    <div class="management-grid">
        <div class="table-panel">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th style="width:30%;">Tên</th>
                            <th style="width:30%;">Địa điểm</th>
                            <th style="width:10%;">Phòng</th>
                            <th style="width:10%;">Bình luận</th>
                            <th style="width:20%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Hotels != null && Model.Hotels.Any())
                        {
                            foreach (var hotel in Model.Hotels)
                            {
                                <tr>
                                    <td>@hotel.TenKS</td>
                                    <td>@hotel.DiaDiem</td>
                                    <td>@hotel.RoomsCount</td>
                                    <td>@hotel.CommentCount</td>
                                    <td>
                                        <button type="button" class="btn-link btn-edit-hotel"
                                                data-id="@hotel.MaKS"
                                                data-name="@hotel.TenKS"
                                                data-location="@hotel.DiaDiem"
                                                data-description="@Html.AttributeEncode(hotel.MoTa ?? "")">
                                            <i class="fas fa-edit"></i> Sửa
                                        </button>
                                        <form method="post" action="@Url.Action("DeleteHotel", "Hotels", new { area = "Admin" })" class="inline-form" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách sạn này không?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maKS" value="@hotel.MaKS" />
                                            <button type="submit" class="btn-link text-danger">
                                                <i class="fas fa-trash-alt"></i> Xóa
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center-placeholder">Không có khách sạn nào để hiển thị.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

      
        <div class="form-panel">
            <h3 id="formTitle">Thêm mới Khách sạn</h3>
            <form id="hotelForm" method="post" action="@Url.Action("SaveHotel", "Hotels", new { area = "Admin" })">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MaKS" id="hotelId" value="0" />

                <label for="hotelName">Tên khách sạn <span class="required-star">*</span></label>
                <input id="hotelName" name="TenKS" type="text" placeholder="Nhập tên khách sạn" required />

                <label for="hotelLocation">Địa điểm <span class="required-star">*</span></label>
                <input id="hotelLocation" name="DiaDiem" type="text" placeholder="Ví dụ: Hà Nội" required />

                <label for="hotelDescription">Mô tả ngắn</label>
                <textarea id="hotelDescription" name="MoTa" rows="4" placeholder="Mô tả tóm tắt về khách sạn"></textarea>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" id="resetHotelForm">
                        <i class="fas fa-undo"></i> Làm mới
                    </button>
                    <button type="submit" class="btn-luxury" id="saveHotelBtn">
                        <i class="fas fa-save"></i> Lưu khách sạn
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<style>
    /* ==================================== */
    /* PHẦN CHUNG CỦA TRANG */
    /* ==================================== */
    .admin-section {
        margin-bottom: 40px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 30px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 15px;
    }

        .section-header h2 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 5px;
        }

        .section-header .overview-note {
            font-size: 1rem;
            color: var(--text-muted);
        }

    .management-grid {
        display: grid;
        /* Tỷ lệ 3fr (rộng hơn) cho bảng (trái), 1.2fr cho form (phải) */
        grid-template-columns: 3fr 1.2fr;
        gap: 30px;
    }

    /* ==================================== */
    /* TABLE PANEL */
    /* ==================================== */
    .table-panel {
        background: var(--surface);
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 24px;
        box-shadow: 0 15px 30px rgba(2, 6, 23, 0.55);
        overflow-x: auto;
    }

    .table-wrapper {
        width: 100%;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        color: var(--text);
        min-width: 750px;
    }

        table thead {
            background: rgba(255, 255, 255, 0.06);
        }

        table th {
            font-weight: 600;
            text-align: left;
            padding: 14px 18px;
            font-size: 0.95rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        table td {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            font-size: 1rem;
            color: var(--text);
            vertical-align: top;
        }

        table tbody tr:last-child td {
            border-bottom: none;
        }

        table tbody tr:hover {
            background-color: rgba(56, 189, 248, 0.05);
        }

    .text-center-placeholder {
        text-align: center;
        color: var(--text-muted);
        font-style: italic;
        padding: 30px 18px !important;
    }

    .text-nowrap {
        white-space: nowrap;
    }

    /* ==================================== */
    /* FORM PANEL */
    /* ==================================== */
    .form-panel {
        background: var(--surface);
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 24px;
        box-shadow: 0 15px 30px rgba(2, 6, 23, 0.55);
        display: flex;
        flex-direction: column;
        gap: 0;
    }

        .form-panel h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 20px;
        }

        .form-panel form {
            display: flex;
            flex-direction: column;
        }

    .required-star {
        color: var(--danger);
        font-weight: 700;
        margin-left: 2px;
    }

    .form-panel label {
        font-weight: 600;
        display: block;
        margin-bottom: 6px;
        font-size: 15px;
        color: var(--text-muted);
        letter-spacing: 0.02em;
        margin-top: 15px;
    }

    .form-panel form label:first-of-type {
        margin-top: 0;
    }

    .form-panel input[type="text"],
    .form-panel input[type="date"],
    .form-panel select,
    .form-panel textarea {
        width: 100%;
        border: 1px solid var(--border);
        background: var(--surface-alt);
        color: var(--text);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 16px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        appearance: none;
    }

        .form-panel input[type="text"]:focus,
        .form-panel input[type="date"]:focus,
        .form-panel select:focus,
        .form-panel textarea:focus {
            border-color: var(--primary);
            background: rgba(56, 189, 248, 0.1);
            outline: none;
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
        }

    .form-panel textarea {
        resize: vertical;
        min-height: 80px;
        padding: 14px;
    }

    /* ==================================== */
    /* FORM ACTIONS & BUTTONS */
    /* ==================================== */
    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        justify-content: flex-end;
    }

    /* Nút chính (Lưu/Lưu khách sạn) */
    .btn-luxury {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--primary);
        color: var(--bg);
        padding: 12px 22px;
        border-radius: 12px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        min-width: 120px;
    }

        .btn-luxury:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, var(--accent-strong), #0ea5e9);
            box-shadow: 0 8px 18px rgba(56, 189, 248, 0.35);
        }

    /* Nút Cảnh báo/Cập nhật (Màu Cam) */
    .btn-warn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--warn, #f4a261);
        color: var(--bg);
        padding: 12px 22px;
        border-radius: 12px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        min-width: 120px;
    }

        .btn-warn:hover {
            transform: translateY(-2px);
            background: #e77e38;
            box-shadow: 0 8px 18px rgba(244, 162, 97, 0.4);
        }

    /* Nút phụ (Làm mới) */
    .btn.btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--surface-alt);
        color: var(--text-muted);
        padding: 12px 22px;
        border-radius: 12px;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        font-weight: 600;
        min-width: 100px;
    }

        .btn.btn-secondary:hover {
            background: rgba(255, 255, 255, 0.08);
            color: var(--text);
            border-color: rgba(255, 255, 255, 0.15);
        }

    /* Nút hành động trong bảng (Sửa, Xóa) */
    .btn-link {
        background: none;
        border: none;
        padding: 6px 8px;
        font-size: 1rem;
        font-weight: 500;
        color: var(--accent);
        cursor: pointer;
        transition: color 0.2s ease, text-decoration 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

        .btn-link:hover {
            text-decoration: underline;
            color: var(--accent-strong);
        }

        .btn-link.text-danger {
            color: var(--danger, #ef4444);
        }

            .btn-link.text-danger:hover {
                color: var(--warn, #f4a261);
            }

    .inline-form {
        display: inline-block;
        margin-left: 8px;
    }

    /* ==================================== */
    /* RESPONSIVE */
    /* ==================================== */
    @@media (max-width: 992px) {
        .management-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@section scripts
{
    <script>
        $(function () {

            // Khởi tạo tiêu đề form lần đầu
            $('#formTitle').text('Thêm mới Khách sạn');

            // Reset Form và đổi nút về trạng thái Lưu
            function resetForm() {
                $('#hotelId').val(0);
                $('#hotelForm')[0].reset();
                $('#saveHotelBtn').html('<i class="fas fa-save"></i> Lưu khách sạn')
                    .removeClass('btn-warn')
                    .addClass('btn-luxury');
                $('#formTitle').text('Thêm mới Khách sạn');
            }

            // Xử lý sự kiện nút Làm mới (Reset)
            $('#resetHotelForm').on('click', resetForm);

            // Xử lý sự kiện nút Sửa
            $('.btn-edit-hotel').on('click', function () {
                var btn = $(this);
                var hotelId = btn.data('id');

                // Đổ dữ liệu vào Form
                $('#hotelId').val(hotelId);
                $('#hotelName').val(btn.data('name'));
                $('#hotelLocation').val(btn.data('location'));
                $('#hotelDescription').val(btn.data('description'));

                // Cập nhật nút thành Cập nhật (Màu Cam/Warn)
                $('#saveHotelBtn').html('<i class="fas fa-sync-alt"></i> Cập nhật')
                    .removeClass('btn-luxury')
                    .addClass('btn-warn');

                // Cập nhật tiêu đề Form
                $('#formTitle').text('Cập nhật Khách sạn (ID: ' + hotelId + ')');

                // Cuộn lên form
                $('html, body').animate({
                    scrollTop: $(".form-panel").offset().top - 20
                }, 500);
            });

            // Đảm bảo nút Lưu có icon ngay cả khi load trang
            $('#saveHotelBtn').html('<i class="fas fa-save"></i> Lưu khách sạn');
        });
    </script>
}