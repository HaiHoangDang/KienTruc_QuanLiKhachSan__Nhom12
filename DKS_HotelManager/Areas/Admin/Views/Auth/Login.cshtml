@{
    ViewBag.Title = "Đăng nhập Admin";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <h2>Đăng nhập Admin</h2>
        <p>Đăng nhập để tiếp cận trang quản lý và thống kê.</p>
        @using (Html.BeginForm("Login", "Auth", FormMethod.Post, new { area = "Admin" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            @Html.ValidationSummary(true, "", new { @class = "text-danger validation-error" })

            <div class="form-group">
                <label for="username">Tên đăng nhập</label>
                <input id="username" name="username" type="text" placeholder="Nhập tên đăng nhập" required />
            </div>
            <div class="form-group">
                <label for="password">Mật khẩu</label>
                <input id="password" name="password" type="password" placeholder="Nhập mật khẩu" required />
            </div>
            <button type="submit" class="btn-primary-admin">Đăng nhập</button>
        }
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 85px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 15px;
    }

    .auth-card {
        background: var(--surface-alt);
        padding: 40px;
        border-radius: 20px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.05);
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--text);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .auth-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.45), 0 0 0 1px var(--accent-strong);
    }

    .auth-card h2 {
        margin-bottom: 12px;
        font-weight: 700;
        font-size: 1.8rem;
        color: var(--accent-strong);
        letter-spacing: 0.02em;
    }

    .auth-card p {
        color: var(--text-muted);
        margin-bottom: 30px;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

    .form-group label {
        font-weight: 600;
        display: block;
        margin-bottom: 8px;
        font-size: 14px;
        color: var(--text-muted);
    }

    .form-group input {
        width: 100%;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        border-radius: 12px;
        padding: 14px 16px;
        font-size: 16px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: #0b1221;
    }

    .form-group input::placeholder {
        color: rgba(248, 251, 255, 0.4);
    }

    .form-group input:focus {
        border-color: var(--primary);
        background: rgba(56, 189, 248, 0.1);
        outline: none;
        box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
    }

    .btn-primary-admin {
        width: 100%;
        padding: 15px;
        border-radius: 14px;
        border: none;
        font-size: 1.05rem;
        font-weight: 700;
        background: var(--primary);
        color: var(--bg);
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        margin-top: 15px;
    }

    .btn-primary-admin:hover {
        transform: translateY(-2px);
        background: linear-gradient(135deg, var(--accent-strong), #0ea5e9);
        box-shadow: 0 8px 20px rgba(56, 189, 248, 0.3);
    }

    .validation-error {
        color: var(--warn);
        background-color: rgba(244, 162, 97, 0.1);
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
        text-align: center;
        font-size: 0.9rem;
        list-style: none;
        display: block;
    }
</style>
