@model DKS_HotelManager.Areas.Staff.ViewModels.StaffCheckoutViewModel
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Khu vực thanh toán";
    var hotelNameDisplay = string.IsNullOrWhiteSpace(Model.SelectedHotelName)
        ? "Chưa chọn chi nhánh"
        : Model.SelectedHotelName;
    var staffNameDisplay = string.IsNullOrWhiteSpace(Model.StaffName)
        ? "Nhân viên lễ tân"
        : Model.StaffName;
    var totalRemaining = Model.TotalRemainingBalance;
    var totalOutstanding = Model.TotalOutstandingBalance;
}

<style>
    .staff-checkout {
        padding: 48px;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        background: transparent;
        color: #f1f5f9;
        min-height: 100%;
        display: flex;
        flex-direction: column;
        gap: 26px;
    }

    .checkout-hero {
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: radial-gradient(circle at top right, rgba(14, 165, 233, 0.2), transparent 45%),
            linear-gradient(180deg, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.85));
        padding: 36px;
        box-shadow: 0 25px 60px rgba(2, 6, 23, 0.5);
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .hero-info small {
        font-size: 12px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(248, 250, 252, 0.65);
    }

    .hero-info h1 {
        margin: 8px 0;
        font-size: clamp(1.9rem, 2.8vw, 2.6rem);
    }

    .hero-info p {
        max-width: 620px;
        color: rgba(248, 250, 252, 0.7);
        line-height: 1.6;
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .hero-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 14px;
    }

    .hero-meta div {
        border-radius: 16px;
        padding: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(15, 23, 42, 0.55);
    }

    .hero-meta span {
        display: block;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(248, 250, 252, 0.54);
    }

    .hero-meta strong {
        display: block;
        margin-top: 6px;
        font-size: 15px;
        color: #ffffff;
    }

    .checkout-status {
        margin-top: 0;
    }

    .status-band {
        border-radius: 22px;
        border: 1px solid rgba(14, 165, 233, 0.35);
        padding: 20px;
        background: linear-gradient(90deg, rgba(14, 165, 233, 0.12), rgba(2, 6, 23, 0.9));
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .status-band__primary,
    .status-band__secondary {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .status-band span {
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #7dd3fc;
    }

    .status-band strong {
        font-size: 26px;
        margin: 0;
        color: #e2e8f0;
    }

    .status-band__primary button {
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 10px 18px;
        background: transparent;
        color: #ffffff;
        cursor: pointer;
        font-weight: 600;
        transition: border-color 0.2s ease;
    }

    .status-band__primary button:hover {
        border-color: rgba(14, 165, 233, 0.6);
    }

    .status-band__secondary span {
        color: rgba(248, 250, 252, 0.65);
    }

    .checkout-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 26px;
    }

    .checkout-card {
        background: rgba(15, 23, 42, 0.85);
        border-radius: 24px;
        padding: 26px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 15px 40px rgba(2, 6, 23, 0.45);
        display: flex;
        flex-direction: column;
        gap: 16px;
        color: #e2e8f0;
    }

    .checkout-card header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        color: #f8fafc;
    }

    .reference {
        font-weight: 600;
        color: #f8fafc;
    }

    .badge {
        font-size: 12px;
        color: #38bdf8;
    }

    dl {
        margin: 0;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    dt {
        font-size: 11px;
        color: rgba(248, 250, 252, 0.55);
        text-transform: uppercase;
        letter-spacing: 0.3em;
    }

    dd {
        margin: 0;
        font-weight: 600;
        color: #f8fafc;
    }

    .checkout-card p {
        margin: 0;
        color: rgba(248, 250, 252, 0.6);
        line-height: 1.6;
    }

    .card-actions {
        margin-top: auto;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .cta {
        border-radius: 999px;
        padding: 12px 20px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        font-size: 14px;
        transition: transform 0.2s ease;
        min-width: 190px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .cta--orange {
        background: linear-gradient(135deg, #f97316, #ef4444);
        color: #fff;
    }

    .cta--ghost {
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: transparent;
        color: #f8fafc;
    }

    .cta:hover {
        transform: translateY(-2px);
    }

    .staff-alert {
        padding: 12px 16px;
        border-radius: 12px;
        background: rgba(34, 197, 94, 0.14);
        color: #064e3b;
        border: 1px solid rgba(34, 197, 94, 0.4);
    }

    .checkout-empty {
        padding: 26px;
        border-radius: 18px;
        border: 1px dashed rgba(248, 250, 252, 0.3);
        background: rgba(15, 23, 42, 0.75);
        font-weight: 600;
        color: rgba(248, 250, 252, 0.8);
        text-align: center;
    }

    @@media (max-width: 768px) {
        .staff-checkout {
            padding: 32px 20px;
        }

        .checkout-hero {
            padding: 24px;
        }

        .status-band {
            padding: 16px;
        }

        .checkout-card {
            padding: 22px;
        }
    }
</style>

<div class="staff-checkout">
    <div class="checkout-hero">
        <div class="hero-info">
            <small>Realtime desk</small>
            <h1>Trả phòng</h1>
            <p>Thanh toán tiền mặt để giải phóng phòng, kiểm tra dịch vụ và cập nhật trạng thái hoàn tất cho chi nhánh hiện tại.</p>
            <div class="hero-actions">
                <a class="cta cta--orange" href="@Url.Action("Index", "Operations", new { area = "Staff" })">
                    Xem booking
                </a>
            </div>
        </div>
        <div class="hero-meta">
            <div>
                <span>Chi nhánh</span>
                <strong>@hotelNameDisplay</strong>
            </div>
            <div>
                <span>Nhân viên</span>
                <strong>@staffNameDisplay</strong>
            </div>
            <div>
                <span>Lưu ý</span>
                <strong>Danh sách hiển thị phòng đang sử dụng tại chi nhánh đã chọn.</strong>
            </div>
        </div>
    </div>

    <div class="checkout-status">
        <div class="status-band">
            @if (Model.Cards.Any())
            {
                <div class="status-band__primary">
                    <div>
                        <span>Thanh toán hoàn tất</span>
                        <strong>@totalRemaining.ToString("N0")₫</strong>
                    </div>
                    <a class="cta cta--ghost" href="@Url.Action("Index", "CheckIn", new { area = "Staff" })">Xác thực ra khách</a>
                </div>
                <div class="status-band__secondary">
                    <span>Đang chờ thu tiền mặt</span>
                    <strong>@totalOutstanding.ToString("N0")₫</strong>
                </div>
            }
            else
            {
                <div class="status-band__empty">
                    Hiện không có phòng nào đang sử dụng để thanh toán tại chi nhánh này.
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.AlertMessage))
    {
        <div class="staff-alert">@Model.AlertMessage</div>
    }

    @if (Model.Cards.Any())
    {
        <div class="checkout-grid">
            @foreach (var card in Model.Cards)
            {
                <article class="checkout-card">
                    <header>
                        <div>
                            <div class="reference">@card.ReferenceNumber</div>
                            <div class="badge">@card.HotelName</div>
                        </div>
                        <div class="badge">@card.RoomName</div>
                    </header>

                    <dl>
                        <dt>Khách</dt>
                        <dd>@card.GuestName</dd>
                        <dt>Check-in</dt>
                        <dd>@(card.CheckIn.HasValue ? card.CheckIn.Value.ToString("dd/MM/yyyy") : "-")</dd>
                        <dt>Check-out</dt>
                        <dd>@(card.CheckOut.HasValue ? card.CheckOut.Value.ToString("dd/MM/yyyy") : "-")</dd>
                        <dt>Đặt cọc</dt>
                        <dd>@card.DepositAmount.ToString("N0")₫</dd>
                        <dt>Còn lại</dt>
                        <dd>@card.RemainingBalance.ToString("N0")₫</dd>
                    </dl>

                    <p>Chỉ thu tiền mặt đặt cọc để giữ chỗ cho khách, phần còn lại thu trực tiếp khi khách nhận phòng.</p>

                    <div class="card-actions">
                        @using (Html.BeginForm("PayWithVnPay", "Checkout", FormMethod.Post, new { area = "Staff" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@card.BookingId" />
                            <button type="submit" class="cta cta--orange">Thanh toán VNPAY</button>
                        }

                        @using (Html.BeginForm("PayCash", "Checkout", FormMethod.Post, new { area = "Staff" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@card.BookingId" />
                            <button type="submit" class="cta cta--ghost">Thanh toán tiền mặt</button>
                        }
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="checkout-empty">
            Hiện không có khách hàng nào đang sử dụng phòng tại chi nhánh đã chọn.
        </div>
    }
</div>
